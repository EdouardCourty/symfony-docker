; Pool PHP-FPM dédié à l'application, isolé du pool www par défaut.
; Tuning "ondemand" : pas de process PHP résident tant qu'il n'y a pas de requête —
; économise la RAM sur un petit VPS (cf. deployment/documentation.md).

[app]
user = __APP_USER__
group = __APP_USER__

listen = /run/php/php__PHP_VERSION__-fpm-app.sock
listen.owner = www-data
listen.group = www-data

pm = ondemand
pm.max_children = 4
pm.process_idle_timeout = 30s
pm.max_requests = 500

php_admin_value[error_log] = /var/log/php__PHP_VERSION__-fpm-app.log
php_admin_flag[log_errors] = on
